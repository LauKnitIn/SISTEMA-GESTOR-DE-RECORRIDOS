@startuml
title Cambiar Contraseña

|Usuario|
start
:1. Selecciona opción "Cambiar contraseña";

|Sistema|
:2. Muestra formulario de cambio;

|Usuario|
:3. Ingresa contraseña actual;

|Sistema|
:Solicita validación de contraseña actual;

|Base de Datos|
:Verifica contraseña actual;

|Sistema|
while (¿Contraseña actual correcta?) is (No)
:Muestra error\n"Contraseña actual incorrecta";
|Usuario|
:Reingresa contraseña actual;
|Sistema|
:Solicita validación de contraseña actual;
|Base de Datos|
:Verifica contraseña actual;
endwhile (Sí)

|Usuario|
:5. Ingresa nueva contraseña;

|Sistema|
:Valida criterios de nueva contraseña;

while (¿Cumple requisitos?) is (No)
:Muestra error y solicita corrección;
|Usuario|
:Reingresa nueva contraseña;
|Sistema|
:Valida criterios de nueva contraseña;
endwhile (Sí)

|Usuario|
:7. Confirma cambio;

|Sistema|
:Solicita actualización de contraseña;

|Base de Datos|
:Actualiza contraseña;

|Sistema|
:9. Notifica cambio exitoso;

stop
@enduml
