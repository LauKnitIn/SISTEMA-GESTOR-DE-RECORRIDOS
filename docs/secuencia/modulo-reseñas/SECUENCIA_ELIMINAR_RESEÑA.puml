@startuml
autonumber

actor Usuario
participant Sistema
database DB

Usuario -> Sistema : irAPerfil()

Sistema --> Usuario : mostrarOpcionesPerfil()

Usuario -> Sistema : seleccionarHistorialRecorridos()

Sistema -> DB : obtenerRecorridosUsuario(usuario)
DB --> Sistema : listaRecorridos

Sistema --> Usuario : mostrarRecorridos()

Usuario -> Sistema : seleccionarRecorrido(idRecorrido)

Sistema -> DB : obtenerReseñasRecorrido(idRecorrido)
DB --> Sistema : listaReseñas

Sistema --> Usuario : mostrarReseñas()

Usuario -> Sistema : elegirReseña(idReseña)

Sistema --> Usuario : mostrarOpcionesReseña()

Usuario -> Sistema : seleccionarBorrarReseña()

Sistema --> Usuario : solicitarConfirmacion()

alt Confirmar eliminación
    Usuario -> Sistema : confirmar()
    Sistema -> DB : eliminarReseña(idReseña)
    DB --> Sistema : confirmacion
    Sistema --> Usuario : reseñaEliminada()
else Cancelar
    Usuario -> Sistema : cancelar()
    Sistema --> Usuario : operacionCancelada()
end

@enduml