@startuml
autonumber

actor Usuario
participant Sistema
database DB

Usuario -> Sistema : irAPerfil()

Sistema -> DB : obtenerRecorridosUsuario(usuario)
DB --> Sistema : listaRecorridos

Sistema --> Usuario : mostrarHistorialRecorridos()

Usuario -> Sistema : seleccionarRecorrido(idRecorrido)

Sistema -> DB : obtenerReseñasRecorrido(idRecorrido)
DB --> Sistema : listaReseñas

Sistema --> Usuario : mostrarReseñas()

alt Filtrar reseñas
    Usuario -> Sistema : aplicarFiltro(criterio)
    Sistema -> DB : consultarReseñasFiltradas(criterio)
    DB --> Sistema : reseñasFiltradas
    Sistema --> Usuario : mostrarReseñasFiltradas()
else Ordenar reseñas
    Usuario -> Sistema : ordenarReseñas(tipoOrden)
    Sistema -> DB : obtenerReseñasOrdenadas(tipoOrden)
    DB --> Sistema : reseñasOrdenadas
    Sistema --> Usuario : mostrarReseñasOrdenadas()
end

Usuario -> Sistema : elegirReseña(idReseña)

Sistema -> DB : obtenerReseña(idReseña)
DB --> Sistema : datosReseña

Sistema --> Usuario : mostrarReseñaEditable()

Usuario -> Sistema : digitarNuevoComentario(texto)
Usuario -> Sistema : darNuevaPuntuacion(valor)

Usuario -> Sistema : guardarCambios()

Sistema --> Usuario : solicitarConfirmacion()

alt Confirmar cambios
    Usuario -> Sistema : confirmarCambios()
    Sistema -> DB : actualizarReseña(idReseña, comentario, puntuacion)
    DB --> Sistema : confirmacionActualizacion
    Sistema --> Usuario : reseñaActualizada()
else Cancelar
    Usuario -> Sistema : cancelarEdicion()
    Sistema --> Usuario : operacionCancelada()
end

@enduml