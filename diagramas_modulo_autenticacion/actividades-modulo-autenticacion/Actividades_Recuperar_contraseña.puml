@startuml
title Recuperar Contraseña

|Usuario|
start
:Selecciona "¿Olvidó su contraseña?";

|Sistema|
:Muestra formulario de recuperación;

|Usuario|
:Ingresa correo electrónico;

|Sistema|
:Solicita verificación de correo;

|Base de Datos|
:Consulta existencia de correo;
:Retorna resultado;

|Sistema|
if (¿Correo registrado?) then (Sí)
  :Genera código de recuperación;
  :Envía código al correo;
  :Muestra campo para ingreso de código;
  |Usuario|
  :Ingresa código de recuperación;
  |Sistema|
  :Valida código;
  if (¿Código válido?) then (Sí)
    :Solicita nueva contraseña;
    |Usuario|
    :Ingresa nueva contraseña;
    :Confirma cambio;
    |Sistema|
    :Solicita actualización de contraseña;
    |Base de Datos|
    :Actualiza contraseña;
    :Retorna confirmación;
    |Sistema|
    :Notifica cambio exitoso;
    stop
  else (No)
    |Sistema|
    :Muestra error "Código inválido";
    stop
  endif
else (No)
  |Sistema|
  :Muestra error "Correo no registrado";
  stop
endif
@enduml
