@startuml
left to right direction

actor Usuario
actor "Usuario Autenticado" as UA
actor Administrador


UA --|> Usuario
Administrador --|> Usuario

rectangle "Sistema de Recorridos Turísticos" {

  usecase "Dejar reseña" as UC1

  usecase "Seleccionar recorrido" as UC8
  usecase "Explorar reseñas" as UC7
  usecase "Seleccionar agregar reseña" as UC6
  usecase "Asignar puntuación" as UC5
  usecase "Redactar reseña" as UC4
  usecase "Publicar reseña" as UC3
  usecase "Cancelar" as UC2

}

Usuario --> UC1

UC1 .> UC2 : <<include>>
UC1 .> UC3 : <<include>>
UC1 .> UC4 : <<include>>
UC1 .> UC5 : <<include>>
UC1 .> UC6 : <<include>>
UC1 .> UC7 : <<include>>
UC1 .> UC8 : <<include>>

UC2 -[hidden]-> UC3
UC3 -[hidden]-> UC4
UC4 -[hidden]-> UC5
UC5 -[hidden]-> UC6
UC6 -[hidden]-> UC7
UC7 -[hidden]-> UC8
@enduml