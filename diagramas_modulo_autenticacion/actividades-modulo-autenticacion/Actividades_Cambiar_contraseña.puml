@startuml
title Cambiar Contraseña

|Usuario|
start
:Selecciona opción "Cambiar contraseña";

|Sistema|
:Muestra formulario de cambio;

|Usuario|
:Ingresa nueva contraseña;

|Sistema|
:Valida criterios de nueva contraseña;

while (¿Cumple requisitos?) is (No)
:Muestra error y solicita corrección;
|Usuario|
:Reingresa nueva contraseña;
|Sistema|
:Valida criterios de nueva contraseña;
endwhile (Sí)

|Usuario|
:Confirma cambio;

|Sistema|
:Solicita actualización de contraseña;

|Base de Datos|
:Actualiza contraseña;

|Sistema|
:Notifica cambio exitoso;

stop
@enduml
