@startuml Casos de Uso - Guardar Recorrido
left to right direction

actor "Usuario Autenticado" as UA
actor "Administrador" as Admin
actor "Usuario" as User


rectangle "Sistema de Gestión de Recorridos Turísticos" {
  usecase "Guardar recorrido" as UC1
  usecase "Seleccionar recorrido" as UC2
  usecase "Ver información\ndel recorrido" as UC3
  usecase "Verificar autenticación" as UC5
  usecase "Mostrar confirmación" as UC7
  usecase "Iniciar sesión" as UC8
}

UA    --> User
Admin --> User
User  --> UC1

UC1 .> UC2 : <<Include>>
UC1 .> UC3 : <<Include>>
UC1 .> UC5 : <<Include>>
UC1 .> UC7 : <<Include>>
UC8 .> UC1 : <<Include>>

UC2 -[hidden]-> UC3
UC7 -[hidden]-> UC8

@enduml
